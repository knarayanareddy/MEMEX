# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# Virtual environments
.venv/
venv/
env/
.Python

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Testing
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml
.nox/

# MEMEX data (never commit user data)
.memex/
memex.db
*.db

# Build artifacts
*.o
*.pyd

# Logs
*.log

# Environment
.env
.env.*

# OS
Thumbs.db
Desktop.ini

# Project specific
*.sqlite3
